{# SVG icon library — inline strings used by macros below. #}

{% macro icon(name) %}
{%- if name == "bio" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="4.2" r="2.2" stroke="currentColor" stroke-width="1.4"/><path d="M2 12c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
{%- elif name == "research" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="1.6" fill="currentColor"/><ellipse cx="7" cy="7" rx="5.8" ry="2.3" stroke="currentColor" stroke-width="1.2"/><ellipse cx="7" cy="7" rx="5.8" ry="2.3" stroke="currentColor" stroke-width="1.2" transform="rotate(60 7 7)"/><ellipse cx="7" cy="7" rx="5.8" ry="2.3" stroke="currentColor" stroke-width="1.2" transform="rotate(120 7 7)"/></svg>
{%- elif name == "work" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1.5" y="4" width="11" height="8.5" rx="1.4" stroke="currentColor" stroke-width="1.4"/><path d="M4.6 4V3a2.4 2.4 0 014.8 0v1" stroke="currentColor" stroke-width="1.4"/><line x1="1.5" y1="7.6" x2="12.5" y2="7.6" stroke="currentColor" stroke-width="1.4"/></svg>
{%- elif name == "edu" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 5.2L7 2.5l6 2.7-6 2.7-6-2.7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M3.5 6.5v3c0 1 1.6 2 3.5 2s3.5-1 3.5-2v-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><line x1="12.3" y1="5.5" x2="12.3" y2="9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
{%- elif name == "grant" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1.5l1.3 2.6 2.9.4-2.1 2 .5 2.9L7 8.1l-2.6 1.3.5-2.9-2.1-2 2.9-.4L7 1.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/><line x1="4.5" y1="12.5" x2="9.5" y2="12.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><line x1="7" y1="9.5" x2="7" y2="12.5" stroke="currentColor" stroke-width="1.3"/></svg>
{%- elif name == "training" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1.5" y="2" width="11" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M4.5 12h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M7 10v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M4 5.5l2 2 4-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elif name == "conf" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="4" cy="5" r="1.6" stroke="currentColor" stroke-width="1.3"/><circle cx="10" cy="5" r="1.6" stroke="currentColor" stroke-width="1.3"/><circle cx="7" cy="9" r="1.6" stroke="currentColor" stroke-width="1.3"/><line x1="5.4" y1="5.5" x2="8.6" y2="5.5" stroke="currentColor" stroke-width="1.1"/><line x1="4.8" y1="6.5" x2="6.4" y2="8.1" stroke="currentColor" stroke-width="1.1"/><line x1="9.2" y1="6.5" x2="7.6" y2="8.1" stroke="currentColor" stroke-width="1.1"/></svg>
{%- elif name == "opensource" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="3.2" cy="3" r="1.4" stroke="currentColor" stroke-width="1.3"/><circle cx="3.2" cy="11" r="1.4" stroke="currentColor" stroke-width="1.3"/><circle cx="10.8" cy="7" r="1.4" stroke="currentColor" stroke-width="1.3"/><path d="M3.2 4.4v5.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M3.2 7h4.3a2 2 0 002-2V4.4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elif name == "arrow" -%}
<svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elif name == "arrow-sm" -%}
<svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M1 5h8M6 2l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elif name == "github" -%}
<svg width="11" height="11" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
{%- elif name == "play" -%}
<svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true"><circle cx="14" cy="14" r="11" stroke="currentColor" stroke-width="1.6"/><path d="M11 10.5l8 3.5-8 3.5V10.5z" fill="currentColor"/></svg>
{%- elif name == "chevron-down" -%}
<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- elif name == "chevron-down-sm" -%}
<svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
{%- endif -%}
{% endmacro %}

{% macro sectionHeader(label, iconName) %}
<h2 class="section-header">
  <span class="section-header__bar" aria-hidden="true"></span>
  {% if iconName %}<span class="section-header__icon">{{ icon(iconName) }}</span>{% endif %}
  {{ label }}
</h2>
{% endmacro %}

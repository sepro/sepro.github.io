---
layout: base.njk
permalink: /software/
pageTitle: "Sebastian Proost, PhD — Software"
---
{% from "partials/icons.njk" import icon, sectionHeader %}

{% macro softwareCard(s) %}
  {% set primaryUrl = s.URLs[0].link if s.URLs and (s.URLs | length) else "" %}
  <article class="software-card">
    <div class="software-card__head">
      <h3 class="software-card__name">
        {% if primaryUrl %}<a href="{{ primaryUrl }}" target="_blank" rel="noreferrer noopener">{{ s.name }}</a>{% else %}{{ s.name }}{% endif %}
        {% if s.year %}<span class="software-card__year">({{ s.year }})</span>{% endif %}
      </h3>
      {% if primaryUrl %}
        <a href="{{ primaryUrl }}" class="software-card__arrow" target="_blank" rel="noreferrer noopener" aria-label="Open {{ s.name }}">
          {{ icon("arrow") }}
        </a>
      {% endif %}
    </div>
    <p class="software-card__desc">{{ s.description }}</p>
    <div class="software-card__tags">
      {% if s.URLs %}{% for l in s.URLs %}<a href="{{ l.link }}" class="tag" target="_blank" rel="noreferrer noopener">{{ l.name }}</a>{% endfor %}{% endif %}
    </div>
  </article>
{% endmacro %}

{% macro gameCard(g) %}
  {% set primaryUrl = g.URLs[0].link if g.URLs and (g.URLs | length) else "" %}
  <article class="software-card game-card">
    {% if g.boxart %}
      <div class="game-card__art">
        <img src="{{ g.boxart }}" alt="{{ g.name }} box art" loading="lazy">
      </div>
    {% endif %}
    <div class="game-card__body">
      <div class="software-card__head">
        <h3 class="software-card__name">
          {% if primaryUrl %}<a href="{{ primaryUrl }}" target="_blank" rel="noreferrer noopener">{{ g.name }}</a>{% else %}{{ g.name }}{% endif %}
          {% if g.year %}<span class="software-card__year">({{ g.year }})</span>{% endif %}
        </h3>
        {% if primaryUrl %}
          <a href="{{ primaryUrl }}" class="software-card__arrow" target="_blank" rel="noreferrer noopener" aria-label="Open {{ g.name }}">
            {{ icon("arrow") }}
          </a>
        {% endif %}
      </div>
      <p class="software-card__desc">{{ g.description }}</p>
      <div class="software-card__tags">
        {% if g.URLs %}{% for l in g.URLs %}<a href="{{ l.link }}" class="tag" target="_blank" rel="noreferrer noopener">{{ l.name }}</a>{% endfor %}{% endif %}
      </div>
    </div>
  </article>
{% endmacro %}

<div class="software-grid">
  {% for s in software %}{{ softwareCard(s) }}{% endfor %}
</div>

{{ sectionHeader("Games", "play") }}

<div class="software-grid">
  {% for g in games %}{{ gameCard(g) }}{% endfor %}
</div>

{{ sectionHeader("Open Source Contributions", "opensource") }}

<div class="software-grid">
  {% for s in opensource %}{{ softwareCard(s) }}{% endfor %}
</div>
